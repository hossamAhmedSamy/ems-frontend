# Frontend env. Copy to .env.local for dev overrides; set the same keys on
# Vercel for the deployed env.
#
# Dev: Vite proxies /api → http://localhost:3000, so VITE_API_URL = /api works.
# Prod: set VITE_API_URL to the full Render backend URL (e.g.
#       https://ems-backend.onrender.com/api).

VITE_API_URL=/api
VITE_APP_NAME=EMS v2
VITE_MARKETING_URL=http://localhost:5174
